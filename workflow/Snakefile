            repeat_features=config["phase5_repeat_context"]["repeat_features_output"],
            locus_context=config["phase5_repeat_context"]["locus_context_output"],
            gene_summary=config["phase5_repeat_context"]["gene_summary_output"]
        shell:
            "python -m greenland_shark_longevity.phase5_repeat_context "
            "--config {input.config:q} "
            "--candidate-loci {input.candidate_loci:q} "
            "--figshare-inventory {input.figshare_inventory:q} "
            "--resource-status-output {output.resource_status:q} "
            "--repeat-features-output {output.repeat_features:q} "
            "--locus-context-output {output.locus_context:q} "
            "--gene-summary-output {output.gene_summary:q}"


    rule phase5c_repeat_qc:
        input:
            config="config/config.yaml",
            candidate_loci=config["phase5_repeat_context"]["candidate_loci"],
            phase5_locus_context=config["phase5c_repeat_qc"]["phase5_locus_context"],
            phase5b_inventory=config["phase5c_repeat_qc"]["phase5b_inventory"]
        output:
            integrity=config["phase5c_repeat_qc"]["integrity_output"],
            locus_qc=config["phase5c_repeat_qc"]["locus_qc_output"],
            gene_qc=config["phase5c_repeat_qc"]["gene_qc_output"],
            report=config["phase5c_repeat_qc"]["report_output"]
        shell:
            "python -m greenland_shark_longevity.phase5c_repeat_qc "
            "--config {input.config:q} "
            "--candidate-loci {input.candidate_loci:q} "
            "--phase5-locus-context {input.phase5_locus_context:q} "
            "--phase5b-inventory {input.phase5b_inventory:q} "
            "--integrity-output {output.integrity:q} "
            "--locus-qc-output {output.locus_qc:q} "
            "--gene-qc-output {output.gene_qc:q} "
            "--report-output {output.report:q}"


    rule phase5_evidence_integration:
        input:
            base_evidence=config["phase5_evidence_integration"]["base_evidence"],
            phase4e_evidence=config["phase5_evidence_integration"]["phase4e_evidence"],
            phase5_gene_summary=config["phase5_evidence_integration"]["phase5_gene_summary"],
            phase5c_gene_qc=config["phase5_evidence_integration"]["phase5c_gene_qc"]
        output:
            phase5_evidence=config["phase5_evidence_integration"]["phase5_evidence_output"],
            integrated=config["phase5_evidence_integration"]["integrated_output"],
            report=config["phase5_evidence_integration"]["report_output"]
        shell:
            "python -m greenland_shark_longevity.phase5_evidence_integration "
            "--base-evidence {input.base_evidence:q} "
            "--phase4e-evidence {input.phase4e_evidence:q} "
            "--phase5-gene-summary {input.phase5_gene_summary:q} "
            "--phase5c-gene-qc {input.phase5c_gene_qc:q} "
            "--phase5-evidence-output {output.phase5_evidence:q} "
            "--integrated-output {output.integrated:q} "
            "--report-output {output.report:q}"


if mode in {"phase6_telomere", "phase7_rnaseq_readiness", "phase7b_quantification_strategy", "phase7c_expression_reference", "phase7d_rnaseq_quantification", "phase7e_expression_hardening", "phase8a_expression_integration", "phase8b_final_evidence_scoring", "phase9_report_generation", "phase9_report_package_audit"}:
