if mode == "orthology":
    rule orthofinder_run:
        input:
            config="config/config.yaml",
            manifest="results/orthology/orthofinder_input_manifest.tsv",
            preflight="results/orthology/orthofinder_preflight.tsv"
        output:
            "results/orthofinder/.orthofinder_complete.txt"
        threads:
            config.get("orthofinder", {}).get("threads", 4)
        shell:
            "python -m greenland_shark_longevity.orthofinder_workflow run "
            "--config {input.config} "
            "--manifest {input.manifest} "
            "--marker-output {output}"


    rule orthofinder_parse:
        input:
            marker="results/orthofinder/.orthofinder_complete.txt",
            manifest="results/orthology/orthofinder_input_manifest.tsv"
        output:
            gene_counts="results/orthology/orthogroup_gene_counts_long.tsv",
            species_summary="results/orthology/orthofinder_species_summary.tsv"
        shell:
            "python -m greenland_shark_longevity.orthofinder_workflow parse "
            "--results-dir results/orthofinder "
            "--manifest {input.manifest} "
            "--gene-count-output {output.gene_counts} "
            "--species-summary-output {output.species_summary}"


