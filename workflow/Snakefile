if mode in phase4d_like_modes:
    rule phase4d_consolidation:
        input:
            base_evidence=base_evidence_output,
            gene_summary="results/rescue/phase4c_gene_review_summary.tsv",
            locus_review="results/rescue/phase4c_locus_review.tsv",
            tp53_summary="results/rescue/tp53_targeted_forward_search_summary.tsv"
        output:
            interpretation="results/evidence/phase4d_candidate_interpretation.tsv",
            integrated=phase4d_integrated_output
        shell:
            "python -m greenland_shark_longevity.phase4d_consolidation "
            "--base-evidence {input.base_evidence:q} "
            "--phase4c-gene-summary {input.gene_summary:q} "
            "--phase4c-locus-review {input.locus_review:q} "
            "--tp53-summary {input.tp53_summary:q} "
            "--interpretation-output {output.interpretation:q} "
            "--integrated-output {output.integrated:q}"


if mode in {"phase4e_locus_hardening", "phase5_repeat_context", "phase5c_repeat_qc", "phase6_telomere", "phase7_rnaseq_readiness", "phase7b_quantification_strategy", "phase7c_expression_reference", "phase7d_rnaseq_quantification", "phase7e_expression_hardening", "phase8a_expression_integration", "phase8b_final_evidence_scoring", "phase9_report_generation", "phase9_report_package_audit"}:
    rule phase4e_locus_hardening:
        input:
            phase4c_locus="results/rescue/phase4c_locus_review.tsv",
            domain_integrity="results/rescue/phase4c_rescue_domain_integrity.tsv",
            tp53_alignment_hits="results/rescue/tp53_targeted_forward_alignment_hits.tsv",
            tp53_target_regions="results/rescue/tp53_forward_hit_target_regions.tsv",
            annotation_gff=config["phase4e_locus_hardening"]["annotation_gff"]
        output:
            locus="results/rescue/phase4e_locus_manual_review.tsv",
            summary="results/rescue/phase4e_gene_hardened_summary.tsv",
            evidence="results/evidence/phase4e_hardened_evidence.tsv"
        shell:
            "python -m greenland_shark_longevity.phase4e_locus_hardening "
            "--phase4c-locus-review {input.phase4c_locus:q} "
            "--domain-integrity {input.domain_integrity:q} "
            "--tp53-alignment-hits {input.tp53_alignment_hits:q} "
            "--tp53-target-regions {input.tp53_target_regions:q} "
            "--annotation-gff {input.annotation_gff:q} "
            "--locus-output {output.locus:q} "
            "--summary-output {output.summary:q} "
            "--evidence-output {output.evidence:q}"


if mode in {"phase5_repeat_context", "phase5c_repeat_qc", "phase6_telomere", "phase7_rnaseq_readiness", "phase7b_quantification_strategy", "phase7c_expression_reference", "phase7d_rnaseq_quantification", "phase7e_expression_hardening", "phase8a_expression_integration", "phase8b_final_evidence_scoring", "phase9_report_generation", "phase9_report_package_audit"}:
    rule phase5_repeat_context:
        input:
            config="config/config.yaml",
            candidate_loci=config["phase5_repeat_context"]["candidate_loci"],
            figshare_inventory=config["phase5_repeat_context"]["figshare_inventory"]
        output:
