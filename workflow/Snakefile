        locus_review="results/rescue/phase4c_locus_review.tsv",
        summary="results/rescue/phase4c_gene_review_summary.tsv"
    shell:
        "python -m greenland_shark_longevity.phase4c_locus_review review-loci "
        "--config {input.config:q} "
        "--alignment-hits {input.alignment_hits:q} "
        "--raw-gff {input.raw_gff:q} "
        "--domain-integrity {input.domain_integrity:q} "
        "--target-regions {input.target_regions:q} "
        "--locus-output {output.locus_review:q} "
        "--summary-output {output.summary:q}"


