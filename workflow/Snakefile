    final_targets = ["results/full/not_implemented.txt"]
else:
    raise ValueError(f"Unsupported workflow_mode: {mode}")


rule all:
    input:
        final_targets


rule metadata:
    input:
        "config/config.yaml"
    output:
        "data/metadata/data_manifest.tsv",
        "data/metadata/species_manifest.tsv",
        "data/metadata/resource_status.tsv"
    shell:
        "python -m greenland_shark_longevity.metadata --config {input} --output-dir data/metadata"


rule validate_candidate_panels:
    input:
        "config/candidate_panels.yaml"
    output:
        "results/validation/candidate_panel_validation.tsv"
    shell:
        "python -m greenland_shark_longevity.candidate_panels --input {input} --output {output}"


rule assembly_qc:
    input:
        config["demo_inputs"]["assembly_fasta"]
    output:
        "results/qc/assembly_qc.tsv"
    shell:
        "python -m greenland_shark_longevity.fasta --kind assembly --input {input} --output {output} --resource-id DEMO_ONLY_NOT_BIOLOGICAL_EVIDENCE"


rule protein_qc:
    input:
        config["demo_inputs"]["protein_fasta"]
    output:
        "results/qc/protein_qc.tsv"
    shell:
        "python -m greenland_shark_longevity.fasta --kind protein --input {input} --output {output} --resource-id DEMO_ONLY_NOT_BIOLOGICAL_EVIDENCE"


if mode in {"orthology", "orthology_postprocess", "domain_validation", "annotation_rescue", "genome_validation", "phase4c_review", "phase4d_consolidation", "phase4e_locus_hardening", "phase5_repeat_context", "phase5c_repeat_qc", "phase6_telomere", "phase7_rnaseq_readiness", "phase7b_quantification_strategy", "phase7c_expression_reference", "phase7d_rnaseq_quantification", "phase7e_expression_hardening", "phase8a_expression_integration", "phase8b_final_evidence_scoring", "phase9_report_generation", "phase9_report_package_audit"}:
    rule candidate_integration:
        input:
            candidate_panels="config/candidate_panels.yaml",
            annotation_gff=config["reference_inputs"]["annotation_gff"],
            orthogroup_gene_counts_long="results/orthology/orthogroup_gene_counts_long.tsv",
            gene_coordinates="results/orthology/reference_gene_coordinates.tsv",
            orthofinder_input_manifest="results/orthology/orthofinder_input_manifest.tsv"
        output:
            copy_number="results/orthology/candidate_copy_number.tsv",
            duplication_audit="results/orthology/candidate_duplication_audit.tsv"
        shell:
            "python -m greenland_shark_longevity.candidate_orthofinder "
            "--candidate-panels {input.candidate_panels:q} "
            "--annotation-gff {input.annotation_gff:q} "
            "--orthogroup-gene-counts-long {input.orthogroup_gene_counts_long:q} "
            "--gene-coordinates {input.gene_coordinates:q} "
            "--orthofinder-input-manifest {input.orthofinder_input_manifest:q} "
            "--copy-number-output {output.copy_number:q} "
            "--duplication-audit-output {output.duplication_audit:q}"
else:
    rule candidate_integration:
        input:
            candidate_panels="config/candidate_panels.yaml",
            orthogroups=config["demo_inputs"]["orthogroups"],
            gene_coordinates=config["demo_inputs"]["gene_coordinates"],
            domains=config["demo_inputs"]["domains"],
            expression_support=config["demo_inputs"]["expression_support"]
        output:
            copy_number="results/orthology/candidate_copy_number.tsv",
            duplication_audit="results/orthology/candidate_duplication_audit.tsv"
        shell:
            "python -m greenland_shark_longevity.orthology "
            "--candidate-panels {input.candidate_panels} "
            "--orthogroups {input.orthogroups} "
            "--gene-coordinates {input.gene_coordinates} "
            "--domains {input.domains} "
            "--expression-support {input.expression_support} "
            "--copy-number-output {output.copy_number} "
            "--duplication-audit-output {output.duplication_audit} "
            "--species-id smic --demo-only true"


